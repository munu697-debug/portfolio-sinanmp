{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "routes": [
    { "src": "^/admin(?:\\.html)?$", "dest": "/admin.html" },
    { "src": "^/dashboard(?:\\.html)?$", "dest": "/dashboard.html" },
    { "src": "^/works(?:\\.html)?$", "dest": "/works.html" },
    { "src": "^/image/(.*)$", "dest": "/image/$1" },
    { "src": "^/js/(.*)$", "dest": "/js/$1" },
    { "src": "^/(.*\\.(?:css|js|png|jpg|jpeg|svg|ico|webmanifest|json|txt))$", "dest": "/$1" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
